# Cloubic API configuration for LLM agent PoC
# Copy to .env and fill in actual values (don't commit .env to git)

# API endpoint (OpenAI-compatible /v1/chat/completions assumed)
CLOUBIC_BASE_URL=https://api.cloubic.ai/v1

# API key
CLOUBIC_API_KEY=your_actual_key_here

# Default models (override per-call as needed)
CLOUBIC_MODEL_GEMINI=gemini-3-flash-preview
CLOUBIC_MODEL_CLAUDE=claude-opus-4-8

# Request settings
CLOUBIC_TIMEOUT_SECONDS=120
CLOUBIC_MAX_RETRIES=3
